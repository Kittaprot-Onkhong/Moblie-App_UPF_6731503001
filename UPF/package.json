{
  "name": "poomjai-app",
  "version": "1.0.0",
  "description": "PoomJai - Shopping and Product Discovery App",
  "main": "node_modules/expo/AppEntry.js",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "eject": "expo eject"
  },
  "dependencies": {
    "@expo/metro-runtime": "~3.1.3",
    "@react-navigation/native": "^6.1.10",
    "@react-navigation/native-stack": "^6.9.17",
    "expo": "^54.0.33",
    "expo-camera": "~17.0.10",
    "firebase": "^12.9.0",
    "react": "18.2.0",
    "react-dom": "18.2.0",
    "react-native": "^0.73.11",
    "react-native-gesture-handler": "^2.14.1",
    "react-native-safe-area-context": "^4.7.2",
    "react-native-screens": "^3.26.0",
    "react-native-web": "~0.19.6",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@types/react": "^18.2.0",
    "@types/react-native": "^0.73.0",
    "typescript": "^5.0.0"
  },
  "private": true,
  "expo": {
    "name": "UPF",
    "slug": "poomjai-app",
    "version": "1.0.0",
    "icon": "./assets/UPF1.png",
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTabletMode": true,
      "icon": "./assets/UPF1.png"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/UPF1.png",
        "backgroundColor": "#0a0f0d"
      }
    },
    "web": {
      "favicon": "./assets/UPF1.png"
    }
  }
}