rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Allow admin panel full access to products collection (สินค้า)
    match /{collection}/{document=**} {
      allow read, write: if collection == "สินค้า" || collection == "users";
    }

    // Allow read for all other collections (for admin panel)
    match /{document=**} {
      allow read: if true;
    }
  }
}
